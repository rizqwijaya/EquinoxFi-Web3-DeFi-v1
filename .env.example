# ──────────────────────────────────────────────────────────────
# EquinoxFi — environment template. Copy to `.env` and fill in.
# NEVER commit the real `.env`. Use a DEDICATED test wallet only.
# ──────────────────────────────────────────────────────────────

# ── Deployment (Section 6) ──
# Sepolia HTTPS RPC URL from Alchemy or Infura.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# Private key of a throwaway test wallet (holds only free Sepolia ETH).
PRIVATE_KEY=0xYOUR_TEST_WALLET_PRIVATE_KEY
# Etherscan API key for --verify (https://etherscan.io/myapikey).
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ── Backend indexer/API (Section 7) ──
# Chain read RPC (can reuse SEPOLIA_RPC_URL).
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# Deployed EquinoxVault address.
VAULT_ADDRESS=0xF06C8E0d362D5fdAcd510BBeEEB4b1D45fD059a2
# Block the vault was deployed at — backfill start point.
DEPLOY_BLOCK=10985838
# SQLite cache file path.
DATABASE_PATH=./data/equinoxfi.db
# Port the Fastify API listens on.
PORT=3001

# ── Frontend (Section 8) ──
VITE_BACKEND_URL=http://localhost:3001
VITE_VAULT_ADDRESS=0xF06C8E0d362D5fdAcd510BBeEEB4b1D45fD059a2
VITE_STAKING_TOKEN_ADDRESS=0xfDfd8c74193df960759BF7Ce5d0675D34FFb0531
VITE_REWARD_TOKEN_ADDRESS=0x4fd7848Aed8fc0c2FCca33494e55A0B330eCe17D
VITE_CHAIN_ID=11155111
