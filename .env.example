# ──────────────────────────────────────────────────────────────
# EquinoxFi — environment template. Copy to `.env` and fill in.
# NEVER commit the real `.env`. Use a DEDICATED test wallet only.
# ──────────────────────────────────────────────────────────────

# ── Deployment (Section 6) ──
# Sepolia HTTPS RPC URL from Alchemy or Infura.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# Private key of a throwaway test wallet (holds only free Sepolia ETH).
PRIVATE_KEY=0xYOUR_TEST_WALLET_PRIVATE_KEY
# Etherscan API key for --verify (https://etherscan.io/myapikey).
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ── Backend indexer/API (Section 7) ──
# Chain read RPC (can reuse SEPOLIA_RPC_URL).
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# Stake vaults from DeployStakeVaults.s.sol logs: stake eTKNA (A) / eTKNB (B) → earn eRWD.
VAULT_A_ADDRESS=0x0000000000000000000000000000000000000000
VAULT_B_ADDRESS=0x0000000000000000000000000000000000000000
# Earliest block of the stake-vault deploy — backfill start point.
STAKE_DEPLOY_BLOCK=0
# DEX pair address the swap indexer backfills (from the deploy script logs).
PAIR_ADDRESS=0x0000000000000000000000000000000000000000
# Block the DEX (factory/router/pair) was deployed at. Defaults to DEPLOY_BLOCK.
DEX_DEPLOY_BLOCK=
# SQLite cache file path.
DATABASE_PATH=./data/equinoxfi.db
# Port the Fastify API listens on.
PORT=3001

# ── Frontend (Section 8) ──
VITE_BACKEND_URL=http://localhost:3001
# Stake vaults (stake eTKNA/eTKNB → earn eRWD). Staking tokens are the DEX
# eTKNA/eTKNB (VITE_TOKEN_A_ADDRESS / VITE_TOKEN_B_ADDRESS below).
VITE_VAULT_A_ADDRESS=0x0000000000000000000000000000000000000000
VITE_VAULT_B_ADDRESS=0x0000000000000000000000000000000000000000
VITE_REWARD_TOKEN_ADDRESS=0x4fd7848Aed8fc0c2FCca33494e55A0B330eCe17D
VITE_CHAIN_ID=11155111

# ── DEX / AMM (frontend) ──
# All four from the deploy script logs ("=== EquinoxFi deployment === / -- DEX --").
VITE_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
VITE_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
VITE_PAIR_ADDRESS=0x0000000000000000000000000000000000000000
VITE_TOKEN_A_ADDRESS=0x0000000000000000000000000000000000000000
VITE_TOKEN_B_ADDRESS=0x0000000000000000000000000000000000000000
# INIT_CODE_HASH is printed by the deploy script (logBytes32). Kept here for
# reference only — the router reads it on-chain, the frontend does not need it.
# INIT_CODE_HASH=0x...

# -- RainbowKit / WalletConnect --
# WalletConnect Cloud project id (https://cloud.walletconnect.com).
# Browser-extension wallets work without it; mobile/WalletConnect wallets need a real id.
VITE_WALLETCONNECT_PROJECT_ID=
